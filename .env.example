# ── DATABASE ─────────────────────────────────────────────────────────────

# SQLite file URI — /data should be a Docker volume mount
DATABASE_URL=file:/data/anki-cloud.db

# 32-byte AES-256 key for encrypting OAuth tokens at rest
# Generate: openssl rand -hex 32
TOKEN_ENCRYPTION_KEY=

# ── GOOGLE OAUTH ─────────────────────────────────────────────────────────

# Google OAuth2 app credentials (console.cloud.google.com → APIs & Services → Credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── SYNC SERVER (optional) ───────────────────────────────────────────────

# Auth/storage mode (default: standalone)
#   standalone — SYNC_USER* env vars, local filesystem, no DB or cloud creds needed
#   cloud      — SQLite DB + cloud storage (requires DATABASE_URL, TOKEN_ENCRYPTION_KEY, GOOGLE_CLIENT_*)
# SYNC_MODE=standalone

# Directory for temporary user collection files during sync (default: ~/.syncserver)
# SYNC_BASE=/data/syncserver

# Bind address (default: 0.0.0.0)
# SYNC_HOST=0.0.0.0

# Bind port (default: 8080)
# SYNC_PORT=8080
