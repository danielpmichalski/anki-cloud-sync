# ── MODE ─────────────────────────────────────────────────────────────────────

# Auth/storage mode (default: standalone)
#   standalone — SYNC_USER* env vars, local filesystem, no DB or cloud creds needed
#   cloud      — SQLite DB + cloud storage (requires DATABASE_URL, TOKEN_ENCRYPTION_KEY, GOOGLE_CLIENT_*)
# SYNC_MODE=standalone

# ── STANDALONE MODE ───────────────────────────────────────────────────────────

# Users for standalone mode — add SYNC_USER2, SYNC_USER3, … for additional users
# SYNC_USER1=alice@example.com:secret

# ── CLOUD MODE ────────────────────────────────────────────────────────────────

# SQLite file URI — /data should be a Docker volume mount
DATABASE_URL=file:/data/anki-cloud.db

# 32-byte AES-256 key for encrypting OAuth tokens at rest
# Generate: openssl rand -hex 32
TOKEN_ENCRYPTION_KEY=

# Google OAuth2 app credentials (console.cloud.google.com → APIs & Services → Credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── SYNC SERVER ───────────────────────────────────────────────────────────────

# Directory for temporary user collection files during sync (default: ~/.syncserver)
# SYNC_BASE=/data/syncserver

# Bind address for the Anki sync protocol (default: 0.0.0.0)
# SYNC_HOST=0.0.0.0

# Port for the Anki sync protocol (default: 8080)
# SYNC_PORT=8080

# ── INTERNAL API ──────────────────────────────────────────────────────────────

# Bind address for the internal REST API (default: 127.0.0.1 — set 0.0.0.0 in Docker)
# SYNC_INTERNAL_HOST=127.0.0.1

# Port for the internal REST API (default: 8081)
# SYNC_INTERNAL_PORT=8081

# Bearer token required on every internal API request — if unset, internal API is disabled
# SYNC_INTERNAL_TOKEN=
